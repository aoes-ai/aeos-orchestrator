# Auto-detect text files
* text=auto

# Explicitly mark certain files as text
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.py text eol=lf

# Explicitly mark images as binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.svg binary

# Lock files
package-lock.json -diff
yarn.lock -diff
pnpm-lock.yaml -diff
